{
  "name": "expose-to-reel-de",
  "version": "0.1.0",
  "private": true,
  "description": "Exposé-to-Reel DE — autorisierte Immobilien-Exposés in kinoreife Walkthrough-Videos verwandeln (MVP).",
  "workspaces": [
    "packages/shared",
    "apps/web",
    "apps/worker"
  ],
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:generate": "prisma generate --schema packages/shared/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema packages/shared/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema packages/shared/prisma/schema.prisma",
    "db:seed": "tsx packages/shared/prisma/seed.ts",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:worker": "npm run dev --workspace apps/worker",
    "build": "npm run build --workspace packages/shared && npm run build --workspace apps/worker && npm run build --workspace apps/web",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration-web --project integration-worker"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
